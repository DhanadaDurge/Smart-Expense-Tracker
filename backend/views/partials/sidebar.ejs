<style>
    /* Overlay for the sliding sidebar */
    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        z-index: 1050;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }
    .sidebar-overlay.open {
        opacity: 1;
        visibility: visible;
    }
    .sidebar-overlay-docked {
        display: none !important;
    }

    /* Contrasting Sidebar Background */
    .sidebar {
        position: fixed;
        left: -340px; 
        top: 0;
        height: 100vh;
        height: 100dvh;
        width: 300px;
        background: #10121F; /* Slightly cleaner dark for dock mode */
        border-right: 1px solid rgba(255, 255, 255, 0.05); 
        padding: 24px;
        padding-bottom: 40px; /* Added padding to ensure sign out is visible */
        display: flex;
        flex-direction: column;
        z-index: 1100;
        box-shadow: 10px 0 40px rgba(0, 0, 0, 0.7);
        transition: left 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .sidebar.open {
        left: 0;
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .sidebar-logo {
        font-size: 1.25rem;
        font-weight: 800;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }
    .sidebar-logo i {
        background: var(--primary);
        color: #000;
        padding: 6px;
        border-radius: 6px;
        font-size: 1rem;
    }
    .close-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        color: var(--text-muted);
        font-size: 1rem;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .close-btn:hover {
        color: #fff;
        background: rgba(255,255,255,0.1);
    }

    /* Top User Block */
    .sidebar-user-top {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px;
        background: rgba(0,0,0,0.2);
        border: 1px solid rgba(0,0,0,0.4);
        border-radius: var(--radius-lg);
        margin-bottom: 30px; 
    }
    .user-avatar-top {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--accent-purple));
        color: #fff;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.4);
    }
    .user-details-top {
        flex: 1;
        overflow: hidden;
    }
    .user-details-top p {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0 0 4px 0;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .user-details-top h4 {
        font-size: 1.05rem;
        color: #fff;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 700;
    }

    /* Navigation Links */
    .sidebar-nav {
        list-style: none;
        padding: 0;
        margin: 0;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        overflow-y: auto;
    }
    .sidebar-nav a {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 16px;
        color: var(--text-muted);
        text-decoration: none;
        border-radius: 8px;
        transition: 0.2s ease;
        font-weight: 500;
        font-size: 0.95rem;
    }
    .sidebar-nav a:hover, .sidebar-nav a.active {
        background: rgba(0, 229, 255, 0.08); 
        color: #fff;
    }
    .sidebar-nav a.active i {
        color: var(--primary);
    }
    .sidebar-nav a i {
        width: 20px;
        font-size: 1.1rem;
        text-align: center;
        transition: 0.2s;
        opacity: 0.8;
    }

    /* Small Sign out Button */
    .sidebar-signout-small {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.2s;
        align-self: flex-start;
    }
    .sidebar-signout-small:hover {
        background: rgba(244, 63, 94, 0.1);
        color: #f43f5e;
    }

    /* Docked Sidebar State (Dashboard) */
    @media (min-width: 1025px) {
        .sidebar-docked {
            position: relative !important;
            left: 0 !important;
            height: calc(100vh - 90px) !important;
            height: calc(100dvh - 90px) !important;
            width: 300px !important;
            min-width: 300px !important;
            flex-shrink: 0 !important;
            box-shadow: none !important;
            border-top: none !important;
            z-index: 10 !important;
            padding-bottom: 24px !important;
        }
        
        .sidebar-docked .sidebar-header {
            display: none !important;
        }
    }

    /* On mobile, even if it's "docked" in EJS, we want it to be a drawer */
    @media (max-width: 1024px) {
        .sidebar-docked {
            position: fixed !important;
            left: -340px !important;
            height: 100vh !important;
            height: 100dvh !important;
            width: 300px !important;
            z-index: 1100 !important;
            transition: left 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) !important;
        }
        .sidebar-docked.open {
            left: 0 !important;
        }
        .sidebar-overlay-docked.open {
            display: block !important;
            opacity: 1 !important;
            visibility: visible !important;
        }
    }
</style>

<!-- Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()" <%= typeof isDocked !== 'undefined' && isDocked ? 'class="sidebar-overlay sidebar-overlay-docked"' : 'class="sidebar-overlay"' %>></div>

<!-- Drawer -->
<aside class="sidebar <%= (typeof isDocked !== 'undefined' && isDocked) ? 'sidebar-docked' : '' %>" id="profileSidebar">
    
    <div class="sidebar-header">
        <a href="/home" class="sidebar-logo">
            <i class="fa-solid fa-wallet"></i>
            ExpenseIQ
        </a>
        <button class="close-btn" onclick="toggleSidebar()">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <!-- Top User Block -->
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="sidebar-user-top">
        <div class="user-avatar-top">
            <%= typeof user !== 'undefined' && user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div class="user-details-top">
            <p>Welcome</p>
            <h4><%= user.name %></h4>
        </div>
    </div>
    <% } %>

    <!-- Standard Navigation links -->
    <ul class="sidebar-nav" style="margin-bottom: 20px;">
        <li>
            <a href="/dashboard" class="<%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
                <i class="fa-solid fa-house"></i> Dashboard
            </a>
        </li>
        <li>
            <a href="/upload_data" class="<%= typeof currentPage !== 'undefined' && currentPage === 'upload_data' ? 'active' : '' %>">
                <i class="fa-solid fa-file-invoice-dollar"></i> Manage Expenses
            </a>
        </li>
        <li>
            <a href="/features" class="<%= typeof currentPage !== 'undefined' && currentPage === 'features' ? 'active' : '' %>">
                <i class="fa-solid fa-chart-column"></i> Analytics Overview
            </a>
        </li>
        <li style="margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;">
            <a href="/faq" class="<%= typeof currentPage !== 'undefined' && currentPage === 'faq' ? 'active' : '' %>">
                <i class="fa-regular fa-circle-question"></i> Help & Support
            </a>
        </li>
    </ul>

    <!-- Small Sign Out Button at the very bottom -->
    <% if (typeof user !== 'undefined' && user) { %>
        <a href="/login" class="sidebar-signout-small" title="Sign out safely">
            <i class="fa-solid fa-arrow-right-from-bracket"></i> Sign out
        </a>
    <% } else { %>
        <a href="/login" class="sidebar-signout-small" style="color: var(--primary);">
            <i class="fa-solid fa-arrow-right-to-bracket"></i> Sign in
        </a>
    <% } %>
</aside>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('profileSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (sidebar && overlay) {
            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.remove('open');
                document.body.style.overflow = '';
            } else {
                sidebar.classList.add('open');
                overlay.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
        }
    }
</script>
