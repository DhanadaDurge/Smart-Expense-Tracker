<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExpenseIQ - Web App Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .docked-mode .sidebar { position: relative; left: 0; transition: none; box-shadow: none; border-right: 1px solid rgba(255, 255, 255, 0.05); }
        .docked-mode .sidebar-overlay, .docked-mode .close-btn, .docked-mode .sidebar-header { display: none !important; }
        .docked-mode .nav-container { max-width: 100% !important; padding: 0 40px 0 24px !important; }
        .text-red { color: #f43f5e !important; }
        .text-green { color: #10b981 !important; }
        
        /* Sleek custom select styling */
        .dash-select {
            background: rgba(255,255,255,0.03); 
            color: var(--text-muted); 
            font-size: 0.8rem; 
            border: 1px solid rgba(255,255,255,0.1); 
            padding: 8px 12px; 
            border-radius: 6px; 
            cursor: pointer; 
            outline: none; 
            font-family: 'Inter', sans-serif; 
            transition: all 0.2s ease;
            appearance: none;
            -webkit-appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 10px center;
            background-size: 1em;
            padding-right: 32px;
        }
        .dash-select:hover {
            background-color: rgba(255,255,255,0.08);
            color: #fff;
            border-color: rgba(255,255,255,0.2);
        }
        .dash-select option {
            background: #10121F;
            color: #fff;
        }
    </style>
</head>
<body class="docked-mode" style="margin: 0; padding: 0; background: #060713; overflow: hidden;">

    <%- include("../partials/navbar", { isDocked: true }) %>

    <div class="dashboard-app-layout" style="display: flex; height: calc(100vh - 90px); width: 100%; margin-top: 90px;">
        <!-- Left Sidebar (Docked) -->
        <%- include("../partials/sidebar", { isDocked: true }) %>

        <!-- Main Content Area -->
        <main class="dash-wrapper" style="flex: 1; height: calc(100vh - 90px); overflow-x: hidden; overflow-y: auto; position: relative;">
            <div class="bg-orb bg-orb-1" style="top: -100px; left: -100px; opacity: 0.2;"></div>
            <div class="bg-orb bg-orb-2" style="bottom: -100px; right: -100px; opacity: 0.1;"></div>
            
            <div class="container" style="padding: 40px; max-width: 1400px; margin: 0 auto; position: relative; z-index: 2;">
                <!-- Header -->
                <div class="dash-top-nav" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                    <div>
                        <!-- Softened Font Size -->
                        <h2 style="margin: 0; font-size: 1.4rem; font-weight: 600;">Welcome, <%= typeof user !== 'undefined' ? user.name : 'User' %> 👋</h2>
                    </div>
                    <div style="display: flex; gap: 16px; align-items: center;">
                        <!-- Fully Clickable Native Select -->
                        <select class="dash-select">
                            <option value="this_month">This Month</option>
                            <option value="last_month">Last Month</option>
                            <option value="last_3_months">Last 3 Months</option>
                            <option value="this_year">This Year</option>
                        </select>
                    </div>
                </div>

                <!-- ROW 1: Bar Chart (70%) + Stacked Cards (30%) -->
                <div class="dashboard-grid-r1" style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <!-- Revenue Bar Chart -->
                    <div class="chart-container" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 24px; border-radius: var(--radius-lg);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h4 style="margin: 0; font-size: 0.95rem; font-weight: 500; color: #fff;">Revenue</h4>
                        </div>
                        <div style="height: 250px; position: relative;">
                            <canvas id="monthlyBarChart"></canvas>
                        </div>
                    </div>
                    <!-- Stacked Cards -->
                    <div style="display: flex; flex-direction: column; gap: 24px;">
                        
                        <!-- 1. Total Income -->
                        <div class="summary-card" style="background: rgba(0, 229, 255, 0.05); border: 1px solid rgba(0, 229, 255, 0.2); padding: 20px 24px; border-radius: var(--radius-lg); flex: 1; display:flex; flex-direction:column; justify-content:center; position: relative;">
                            <h3 id="totalIncomeDisplay" style="font-size: 1.6rem; color: #fff; margin: 0 0 6px 0; letter-spacing: -0.5px;">₹0.00</h3>
                            <p style="color: var(--text-muted); margin: 0; font-size: 0.8rem;">Total Income</p>
                            <div style="position: absolute; right: 24px; top: 20px; color: #00e5ff; font-size: 1.2rem;"><i class="fa-solid fa-arrow-turn-down"></i></div>
                        </div>

                        <!-- 2. Total Expenses -->
                        <div class="summary-card" style="background: rgba(244, 63, 94, 0.05); border: 1px solid rgba(244, 63, 94, 0.2); padding: 20px 24px; border-radius: var(--radius-lg); flex: 1; display:flex; flex-direction:column; justify-content:center; position: relative;">
                            <h3 id="totalExpenseDisplay" style="font-size: 1.6rem; color: #fff; margin: 0 0 6px 0; letter-spacing: -0.5px;">₹0.00</h3>
                            <p style="color: var(--text-muted); margin: 0; font-size: 0.8rem;">Total Expenses</p>
                            <div style="position: absolute; right: 24px; top: 20px; color: #f43f5e; font-size: 1.2rem;"><i class="fa-solid fa-arrow-turn-up"></i></div>
                        </div>

                    </div>
                </div>

                <!-- ROW 2: Cashflow Line Chart (70%) + Expenses Donut (30%) -->
                <div class="dashboard-grid-r2" style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 30px;">
                    <!-- Cashflow Line Chart -->
                    <div class="chart-container" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 24px; border-radius: var(--radius-lg);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h4 style="margin: 0; font-size: 0.95rem; font-weight: 500; color: #fff;">Cashflow</h4>
                            <div style="display: flex; gap: 8px;">
                                <span onclick="toggleCashflowDataset(0, this)" style="cursor: pointer; font-size: 0.7rem; background: rgba(0,229,255,0.1); border: 1px solid rgba(0,229,255,0.3); color: #00e5ff; padding: 4px 10px; border-radius: 4px; transition: 0.3s;">Income</span>
                                <span onclick="toggleCashflowDataset(1, this)" style="cursor: pointer; font-size: 0.7rem; background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.3); color: #8b5cf6; padding: 4px 10px; border-radius: 4px; transition: 0.3s;">Expenses</span>
                            </div>
                        </div>
                        <div style="height: 250px; position: relative;">
                            <canvas id="cashflowLineChart"></canvas>
                        </div>
                    </div>
                    <!-- Expense Donut -->
                    <div class="chart-container" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 24px; border-radius: var(--radius-lg); display: flex; flex-direction: column;">
                        <h4 style="margin: 0 0 20px 0; font-size: 0.95rem; font-weight: 500; color: #fff;">Expenses</h4>
                        <div style="flex: 1; position: relative; display: flex; justify-content: center; align-items: center;">
                            <div style="width: 200px; height: 200px;">
                                <canvas id="categoryPieChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ROW 3: Transactions Table -->
                <div class="transactions-container" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: var(--radius-lg); padding: 30px;">
                    <h4 style="margin: 0 0 24px 0; font-size: 0.95rem; font-weight: 500; color: #fff;">Transactions</h4>
                    <table class="dash-table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); text-align: left; color: var(--text-muted); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">
                                <th style="padding-bottom: 16px; font-weight: 600;">ID</th>
                                <th style="padding-bottom: 16px; font-weight: 600;">Type</th>
                                <th style="padding-bottom: 16px; font-weight: 600;">Date</th>
                                <th style="padding-bottom: 16px; text-align: right; font-weight: 600;">Amount</th>
                                <th style="padding-bottom: 16px; text-align: right; font-weight: 600;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof expenses !== 'undefined' && expenses.length > 0) { %>
                                <% expenses.slice(0,5).forEach(expense => { %>
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.02); transition: 0.2s;">
                                        <td style="padding: 16px 0; color: var(--primary); font-size: 0.8rem;">#<%= expense._id.toString().substring(0,6).toUpperCase() %></td>
                                        <td style="padding: 16px 0; color: #fff; font-size: 0.85rem;"><%= expense.title %></td>
                                        <td style="padding: 16px 0; color: var(--text-muted); font-size: 0.8rem;"><%= new Date(expense.date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></td>
                                        <td class="<%= expense.amount > 0 ? 'text-red' : 'text-green' %>" style="padding: 16px 0; text-align: right; font-weight: 600; font-size: 0.9rem;">
                                            ₹<%= expense.amount.toFixed(2) %>
                                        </td>
                                        <td style="padding: 16px 0; text-align: right;">
                                            <span style="background: rgba(16,185,129,0.1); color: #10b981; padding: 6px 12px; border-radius: 6px; font-size: 0.7rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;"><i class="fa-solid fa-circle" style="font-size: 0.4rem;"></i> Completed</span>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 60px; color: var(--text-muted); font-size: 0.85rem;">
                                        No recent transactions recorded.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

            </div>
        </main>
    </div>

    <!-- Hidden data -->
    <script id="expenseData" type="application/json">
        <%- JSON.stringify(typeof expenses !== 'undefined' ? expenses : []) %>
    </script>
    <script src="/js/script.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>
